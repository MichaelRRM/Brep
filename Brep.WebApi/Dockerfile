FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY Brep.WebApi/Brep.WebApi.csproj Brep.WebApi/
RUN dotnet restore Brep.WebApi/Brep.WebApi.csproj
COPY Brep.WebApi/ Brep.WebApi/
WORKDIR /src/Brep.WebApi
RUN dotnet publish -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Brep.WebApi.dll"]
